---
import SectionHeader from "./SectionHeader.astro";
---
<section id="now" class="section section--now">
  <SectionHeader idx={6} file="/now" sub="// inspired by nownownow.com — what i'm actually doing this month" />
  <div class="now-grid">
    <div class="now-card">
      <span class="now-label">reading</span>
      <p>Han Kang — <em>The White Book</em>. Slowly, on the subway. Re-reading <em>Designing Data-Intensive Applications</em> for the third time, but better at it.</p>
    </div>
    <div class="now-card">
      <span class="now-label">writing</span>
      <p>An essay called "Why your design system is a Trello board". Open in a tab since March.</p>
    </div>
    <div class="now-card">
      <span class="now-label">building</span>
      <p>A small Rust CLI that diffs two screenshots and tells you what changed in plain English. WIP.</p>
    </div>
    <div class="now-card">
      <span class="now-label">running</span>
      <p>4x/week along the Han river. 5k PB stuck at 22:14 since 2024 — see open issue #41.</p>
    </div>
    <div class="now-card">
      <span class="now-label">not doing</span>
      <p>Twitter. Crypto. Anything with "agentic" in its README.</p>
    </div>
    <div class="now-card now-card--ts">
      <span class="now-label">last updated</span>
      <p><code>2026-05-11 / 23:41 KST</code></p>
    </div>
  </div>
</section>
